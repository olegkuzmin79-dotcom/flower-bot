BOT_TOKEN=your_production_bot_token

# === Локальная разработка (ПК) ===
# DEV=1
# BOT_TOKEN_DEV=your_dev_bot_token_from_botfather
# TELEGRAM_PROXY=socks5://127.0.0.1:10808

TELEGRAM_PROXY=
YOOKASSA_SHOP_ID=
YOOKASSA_SECRET_KEY=
FLORIST_CHAT_ID=500975404
ADMIN_CHAT_ID=500975404
USE_TEST_PAYMENTS=1

# Админка (бесплатно, на том же Railway-сервисе)
WEB_ADMIN_PASSWORD=change-me-strong-password
